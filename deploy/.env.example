# Pulse production .env — fill in before `docker compose up -d`.
# install.sh generates this automatically with random secrets.

# Secrets (REQUIRED — use long random values, e.g. `openssl rand -hex 32`)
POSTGRES_PASSWORD=change_me
CLICKHOUSE_PASSWORD=change_me
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me

# Public URL agents push telemetry to (set to your domain + put TLS in front)
PUBLIC_INGEST_URL=http://localhost:8080
CORS_ORIGINS=http://localhost

# Optional
HTTP_PORT=80
PULSE_VERSION=latest
# AGENT_IMAGE=ghcr.io/roman0309/pulse-agent:latest
# SEED_DEMO=false

# --- Tailscale (optional: `docker compose --profile tailscale up -d`) ---
# Reachable privately at https://<TS_HOSTNAME>.<your-tailnet>.ts.net (auto HTTPS).
# Create a reusable auth key at https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxx
# TS_HOSTNAME=pulse
# Then set the private URL so the Connect page hands agents the right address:
# PUBLIC_INGEST_URL=https://pulse.your-tailnet.ts.net
# CORS_ORIGINS=https://pulse.your-tailnet.ts.net
