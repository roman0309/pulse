POSTGRES_USER=metrics
POSTGRES_PASSWORD=metrics_secret
POSTGRES_DB=metrics_db

CLICKHOUSE_USER=metrics
CLICKHOUSE_PASSWORD=metrics_secret
CLICKHOUSE_DB=metrics_db

# Auth/encryption secrets. Leave unset and the server generates strong random
# keys on first boot (persisted in Postgres). Set them explicitly to pin the
# values (recommended for multi-replica). Generate with: openssl rand -hex 32
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# CREDENTIALS_KEY=   # encrypts SSH creds & channel secrets; defaults to JWT_SECRET

CORS_ORIGINS=http://localhost:3000

# Externally reachable Pulse URL that remote agents push telemetry to.
# This is the value shown in the Connect page's setup commands.
# Local default: http://localhost:8080. In production set your public domain:
#   PUBLIC_INGEST_URL=https://pulse.example.com
PUBLIC_INGEST_URL=http://localhost:8080
