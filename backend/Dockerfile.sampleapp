# ---- build stage ----
FROM golang:1.24-alpine AS build
WORKDIR /app
RUN apk add --no-cache git
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /sampleapp ./cmd/sampleapp

# ---- runtime stage ----
FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /sampleapp /sampleapp
ENTRYPOINT ["/sampleapp"]
